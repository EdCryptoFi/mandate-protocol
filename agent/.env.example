# ============================================================
#  Mandate Protocol — Agent Configuration
#  NEVER commit a real .env file. Copy this to .env and fill in.
# ============================================================

# Anthropic API Key — required for AI reasoning
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Canton JSON API URL
# Local sandbox:  http://localhost:7575   (HTTP ok for localhost only)
# Canton DevNet:  https://<your-node>.canton.network:7575  (HTTPS required)
# Canton MainNet: https://<your-node>.canton.network:7575  (HTTPS required)
# WARNING: the agent will refuse to connect via HTTP to non-localhost endpoints
CANTON_JSON_API_URL=http://localhost:7575

# Your agent's Canton party ID (get from sandbox output or DevNet portal)
# Format: AIAgent::1220<hex-string>
CANTON_PARTY_ID=AIAgent::1220...

# JWT access token issued by your Canton participant node
# Local sandbox: leave empty — the agent auto-generates a dev JWT
# (HS256, secret "secret") for localhost, since the JSON API always
# needs a token to identify the acting party.
# DevNet/MainNet: required — get from Canton Portal or OAuth2 flow
CANTON_TOKEN=

# Ledger ID used in the auto-generated dev token (local sandbox only)
CANTON_LEDGER_ID=sandbox

# Contract ID of the AgentSession issued to this agent
# Get this from running the Setup.daml script and noting the session contract ID
AGENT_SESSION_CONTRACT_ID=

# How often the agent polls the ledger (seconds)
# Minimum recommended: 2 (avoid rate-limiting the JSON API)
POLL_INTERVAL_SECONDS=3

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
